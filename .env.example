# ══════════════════════════════════════════════════
# PrepVista — Environment Variables
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════

# ── App ──────────────────────────────────────────
APP_NAME="PrepVista"
DEBUG=true
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Admin ────────────────────────────────────────
ADMIN_EMAIL=your_admin_email@example.com

# ── Supabase ─────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
DATABASE_URL=postgresql://postgres:your_password@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Razorpay ─────────────────────────────────────
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── LLM Providers ────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_EVAL_MODEL=llama-3.3-70b-versatile

# OpenAI (fallback)
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ── Upstash Redis (Rate Limiting) ────────────────
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token

# ── Resend (Email) ───────────────────────────────
RESEND_API_KEY=re_your_resend_key
FROM_EMAIL=PrepVista <noreply@prepvista.ai>

# ── SMTP (Manual Signup Verification) ────────────
# Gmail API (Manual Signup Verification)
# Uses HTTPS instead of SMTP for signup OTP and admin notification emails.
GMAIL_API_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GMAIL_API_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_API_REFRESH_TOKEN=your_google_refresh_token
GMAIL_API_FROM_EMAIL=PrepVista <your_email@gmail.com>

# ── Sentry (Monitoring) ─────────────────────────
# SENTRY_DSN=https://your_sentry_dsn
